# Copy to .env and fill in values:
#   cp .env.example .env

DASHSCOPE_API_KEY=sk-your-key-here

# 微信小程序（Docker / 本地 spring-boot 均从 .env 或 shell 注入）
WECHAT_APP_ID=wx-your-appid
WECHAT_APP_SECRET=your-app-secret
# 至少 32 字符的随机串；配置 WECHAT_APP_ID 后启动时会校验
WECHAT_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# 可选：管理员 openid，逗号分隔
WECHAT_BOOTSTRAP_ADMIN_OPENIDS=

# Web 管理台登录（本地 / Docker；至少 32 字符）
WEB_LOGIN_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# 可选，默认 web:console
# WEB_LOGIN_OPENID=web:console
