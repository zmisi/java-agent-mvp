# Copy to .env and set your DashScope API key:
#   cp .env.example .env
DASHSCOPE_API_KEY=sk-your-key-here

# DB Provisioning MCP (optional — defaults: node + ./java-agent-mcp/bin/java-agent-mcp.js)
# Unset JAVA_AGENT_MCP_COMMAND if /usr/local/bin/java-agent-mcp is not installed.
# JAVA_AGENT_MCP_COMMAND=node
# JAVA_AGENT_MCP_SCRIPT=./java-agent-mcp/bin/java-agent-mcp.js

# Chat MCP: admission-score (sibling repo, build before spring-boot:run)
# cd ../admission-score-mcp && npm install && npm run build
# Path in src/main/resources/mcp-servers-config.json: ../admission-score-mcp/dist/index.js
