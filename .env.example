# Copy to .env and fill in values:
#   cp .env.example .env

DASHSCOPE_API_KEY=sk-your-key-here

# 微信小程序（Docker / 本地 spring-boot 均从 .env 或 shell 注入）
WECHAT_APP_ID=wx-your-appid
WECHAT_APP_SECRET=your-app-secret
WECHAT_JWT_SECRET=replace-with-a-long-random-secret
# 可选：管理员 openid，逗号分隔
WECHAT_BOOTSTRAP_ADMIN_OPENIDS=

# DB Provisioning MCP (optional — defaults: node + ./java-agent-mcp/bin/java-agent-mcp.js)
# JAVA_AGENT_MCP_COMMAND=node
# JAVA_AGENT_MCP_SCRIPT=./java-agent-mcp/bin/java-agent-mcp.js
